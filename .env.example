# Copy this file to .env and fill in your key(s). Never commit the real .env file.

# Single-key setup (the common case):
GROQ_API_KEY=gsk_your_key_here

# Multi-account key pool (optional): comma-separated keys, each from a SEPARATE Groq
# account/organization (Groq's rate limits apply per-organization, not per key, so keys from the
# same account do NOT add quota). If set, this takes precedence over GROQ_API_KEY above.
# GROQ_API_KEYS=gsk_account1_key,gsk_account2_key,gsk_account3_key
